{
  "name": "spine-viewer-js",
  "version": "1.0.0",
  "description": "Browser-based Spine viewer and asset inspection utility.",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "desktop:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "desktop": "npm run build && electron .",
    "check": "npm run build",
     "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "@esotericsoftware/spine-pixi-v8": "4.2.119",
    "pixi.js": "8.19.0",
    "vite": "8.0.16"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.company.spineviewer",
    "productName": "Spine Viewer",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools"
    }
  }
}
